# Markdown Notes web app environment
#
# Copy to .env for local overrides. Do not commit .env files.

# Runtime data directory. Defaults to ./data.
# MARKDOWN_NOTES_DATA_DIR=./data

# Local Ollama defaults used by the app.
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2:3b
# OLLAMA_EMBED_MODEL=nomic-embed-text
